# SpotiFLAC — variabili d'ambiente opzionali
# Copia questo file come .env e compila i valori
# Carica con: export $(cat .env | xargs)

# Token Qobuz (x-user-auth-token da DevTools → Network → api.json)
# Serve per migliorare la risoluzione metadati su Qobuz
QOBUZ_AUTH_TOKEN=

# Cookie sp_dc di Spotify (da DevTools → Application → Cookies)
# Serve per i testi sincronizzati tramite il provider Spotify
SPOTIFY_TOKEN=
